{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "sessionModel.ts",
    "sessionService.ts",
    "sessionRoutes.ts",
    "useSessionStorage.ts",
    "db.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "sessionService.test.ts"
  ]
}
