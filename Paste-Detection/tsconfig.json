{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": [
    "pasteDetector.ts",
    "usePasteDetector.ts"
  ],
  "exclude": [
    "node_modules",
    "pasteDetector.test.ts"
  ]
}